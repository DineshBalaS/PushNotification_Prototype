# Copy to .env and fill in values. Do not commit .env.

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=push_notification_prototype

FRONTEND_URL=http://localhost:3000

FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# Required for Novu server API (Dashboard → Settings → API Keys → Secret key)
NOVU_SECRET_KEY=replace-with-your-novu-secret-key

# Workflow identifier from Novu dashboard (immutable); used when triggering appointment push
NOVU_APPOINTMENT_WORKFLOW_ID=appointment-received

# Second workflow for PATCH /appointments/{id}/status (doctor push); create in Novu dashboard
NOVU_APPOINTMENT_STATUS_WORKFLOW_ID=appointment-status-updated

# Optional: novu-py server_url — use for EU region, e.g. https://eu.api.novu.co
# NOVU_SERVER_URL=

# Optional: when multiple FCM integrations exist in Novu (Push channel)
# NOVU_FCM_INTEGRATION_IDENTIFIER=

# Optional: dual-write FCM tokens to Mongo device_tokens (default false; Novu is source of truth)
# PERSIST_DEVICE_TOKENS_IN_MONGO=false
