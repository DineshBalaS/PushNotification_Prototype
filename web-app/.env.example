# Public URL of the FastAPI backend (no trailing slash).
# Local:  http://127.0.0.1:8000  or  http://localhost:8000
# Render: https://<your-service>.onrender.com
# Vercel: set the same variable for Production + Preview so the client bundle points at the right API.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Option A (prototype): fixed MongoDB patient document _id (24 hex chars).
# Copy from your DB after seed, or set per environment (Vercel) to match the patient row
# that receives demo notifications. Must match an existing patient for POST /api/v1/appointments/.
NEXT_PUBLIC_BOOKING_PATIENT_ID=69d20d6cfecbf92ddaf180ef
